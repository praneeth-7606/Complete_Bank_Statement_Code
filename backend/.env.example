# Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# Mistral OCR 3 Configuration (for PDF extraction)
MISTRAL_API_KEY=your_mistral_api_key_here

# MongoDB Configuration
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority

# Pinecone Vector Database Configuration
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=financial-transactions

# Application Configuration
DEBUG=False
LOG_LEVEL=INFO

# Authentication Configuration
SECRET_KEY=generate_with_openssl_rand_hex_32
GOOGLE_CLIENT_ID=your_google_client_id_here
HMAC_SECRET_KEY=generate_with_openssl_rand_hex_32

# Data Encryption Configuration (CRITICAL FOR SECURITY)
# Generate these keys using: python scripts/generate_encryption_key.py
# IMPORTANT: Keep these keys SECRET - never commit actual keys to version control
# Store a secure backup - losing the key means losing access to encrypted data
ENCRYPTION_KEY=generate_using_scripts/generate_encryption_key.py
ENCRYPTION_SALT=generate_using_scripts/generate_encryption_key.py
